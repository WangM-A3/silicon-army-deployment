# ============================================================
# OpenClaw 企业级硅基军团 · 环境变量配置
# ============================================================

# --- OpenClaw 核心配置 ---
OPENCLAW_HOME=./Company_Agent_Brain
OPENCLAW_CONFIG=./openclaw.config.js
OPENCLAW_LOG_LEVEL=info
OPENCLAW_ENV=production

# --- Agent World 统一身份 ---
AGENT_WORLD_API_URL=https://world.coze.site
AGENT_WORLD_API_KEY=agent-world-0ae7ea92741dd05b4f7e73afb3c0e15a404b583f5480007a
AGENT_ID=b665c20e-0ae3-4f66-9a1e-ebf081d10aaa

# --- LLM Provider（按需启用） ---
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_API_BASE=https://api.minimax.chat/v1

# --- 企业知识库 ---
KNOWLEDGE_BASE_PATH=./Company_Agent_Brain/2_agent_knowledge
SKILL_LIB_PATH=./Company_Agent_Brain/2_agent_knowledge/01_skill_lib
TASK_LOG_PATH=./Company_Agent_Brain/2_agent_knowledge/02_task_log

# --- 企业合规与审计 ---
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=./security/audit_logs
ACCESS_CONTROL_PATH=./security/access_control.json
AUDIT_LOG_CONFIG_PATH=./security/audit_log_config.json

# --- 安全模块 ---
PII_DETECTION_ENABLED=true
PII_REDACT_MODE=mask
WHITELIST_DOMAIN_MODE=strict
ALLOWED_DOMAINS=api.openai.com,api.minimax.chat,world.coze.site,xiaping.coze.site

# --- 数据库 ---
SQLITE_DB_PATH=./Company_Agent_Brain/company_brain.db
SQLITE_JOURNAL_MODE=WAL
SQLITE_BUSY_TIMEOUT=30000

# --- MCP Server（可选）---
GITHUB_MCP_TOKEN=ghp_your_github_token_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=T00000000

# --- 企业飞书集成（可选）---
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- 邮件系统 ---
SMTP_HOST=smtp.company.com
SMTP_PORT=465
SMTP_USER=agent@company.com
SMTP_PASSWORD=your_smtp_password_here
EMAIL_FROM=agent@company.com

# --- JWT / 网关安全 ---
JWT_SECRET=openclaw-enterprise-default-secret-change-in-production
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=604800

# --- 限流配置 ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=100

# --- 定时任务 ---
CRON_ENABLED=true
CRON_EXPRESSION=0 8 * * *

# --- 部署模式 ---
DEPLOY_MODE=docker
DOCKER_NETWORK=company_internal
