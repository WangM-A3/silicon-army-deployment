# ============================================
# 外贸硅基军团 - 生产环境配置示例
# ============================================
# 复制此文件为 .env 并填入真实配置
# 所有密钥请勿硬编码到代码中

# ============================================
# MiniMax API 配置
# ============================================
# MiniMax API密钥（从 https://platform.minimax.io 获取）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_URL=https://api.minimax.io/v1/chat/completions
MINIMAX_MODEL=abab6.5s-chat

# ============================================
# 支付宝配置（沙箱环境）
# ============================================
# 沙箱环境配置（开发测试用）
ALIPAY_SANDBOX_MODE=true
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key_here
# 正式环境回调地址
ALIPAY_NOTIFY_URL=https://silicon-army.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://silicon-army.com/payment/success

# ============================================
# 微信支付配置
# ============================================
WECHAT_APP_ID=your_wechat_appid
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_NOTIFY_URL=https://silicon-army.com/api/payment/wechat/notify

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=sqlite:///data/subscribers.db
# 如果使用MySQL：
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/silicon_army

# ============================================
# 应用配置
# ============================================
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
DOMAIN=silicon-army.com
BASE_URL=https://silicon-army.com

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# 邮件配置（可选，用于发送通知）
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@silicon-army.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@silicon-army.com

# ============================================
# Redis缓存配置（可选，提升性能）
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# CORS配置
# ============================================
CORS_ORIGINS=https://silicon-army.com,https://www.silicon-army.com
